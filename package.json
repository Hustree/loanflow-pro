{
  "name": "loanflow-pro",
  "version": "0.1.0",
  "private": false,
  "description": "End-to-end loan application MVP — passkey auth, multi-step apply flow, status management. React 19 + Vite + MUI + Redux Toolkit.",
  "license": "MIT",
  "author": "Joshua Bascos",
  "repository": {
    "type": "git",
    "url": "https://github.com/Hustree/loanflow-pro.git"
  },
  "homepage": "https://github.com/Hustree/loanflow-pro",
  "bugs": "https://github.com/Hustree/loanflow-pro/issues",
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "knip": "knip",
    "prepare": "husky"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@hookform/resolvers": "^5.2.1",
    "@mui/icons-material": "^7.3.0",
    "@mui/material": "^7.3.0",
    "@mui/system": "^7.3.1",
    "@mui/x-data-grid": "^8.10.0",
    "@reduxjs/toolkit": "^2.8.2",
    "@simplewebauthn/browser": "^13.1.2",
    "buffer": "^6.0.3",
    "date-fns": "^4.1.0",
    "firebase": "^12.1.0",
    "i18next": "^23.15.0",
    "i18next-browser-languagedetector": "^8.0.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-hook-form": "^7.62.0",
    "react-i18next": "^15.0.0",
    "react-redux": "^9.2.0",
    "react-responsive": "^10.0.1",
    "react-router-dom": "^7.7.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@axe-core/react": "^4.11.3",
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@playwright/test": "^1.48.0",
    "@storybook/addon-a11y": "^10.3.6",
    "@storybook/addon-essentials": "^8.3.5",
    "@storybook/addon-interactions": "^8.3.5",
    "@storybook/blocks": "^8.3.5",
    "@storybook/react-vite": "^10.3.6",
    "@storybook/test": "^8.3.5",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.4",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^25.6.0",
    "@types/react": "^19.1.9",
    "@types/react-dom": "^19.1.7",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.8.0",
    "@vitejs/plugin-react-swc": "^4.3.0",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/ui": "^4.1.5",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jsx-a11y": "^6.10.0",
    "eslint-plugin-react": "^7.37.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-storybook": "^10.3.6",
    "eslint-plugin-unicorn": "^64.0.0",
    "eslint-plugin-vitest": "^0.5.4",
    "globals": "^17.6.0",
    "husky": "^9.1.6",
    "jsdom": "^29.1.1",
    "knip": "^6.11.0",
    "lint-staged": "^16.4.0",
    "msw": "^2.14.3",
    "prettier": "^3.3.3",
    "storybook": "^10.3.6",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vite-plugin-svgr": "^5.2.0",
    "vitest": "^4.1.5",
    "web-vitals": "^5.2.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml,css}": [
      "prettier --write"
    ]
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
